# DermaScan AI — Backend Configuration Env Template

# App Settings
APP_NAME="DermaScan AI API"
DEBUG=True
SECRET_KEY="replace-this-with-a-very-secure-random-key"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database Configuration
# Leave blank or omit to auto-use local SQLite database (sqlite:///./dermascan.db)
# DATABASE_URL="postgresql://user:password@localhost:5432/dermascan"

# Gemini Vision API Key
# Get your key from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY="AIzaSy..."

# Cloudinary Integration (Optional: fallbacks to local files if not configured)
# CLOUDINARY_CLOUD_NAME="your-cloud-name"
# CLOUDINARY_API_KEY="your-api-key"
# CLOUDINARY_API_SECRET="your-api-secret"
